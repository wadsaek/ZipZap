@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="d-flex flex-column justify-content-between align-items-center mb-5">
    @{
        var welcomeMessage = "Welcome";
        var user = Model.User;
        var accessible = Model.Accessible;
        var shared = Model.Shared;
    }
    @if (user is not null)
    {
        welcomeMessage = $"{welcomeMessage}, {user.Username}";
    }
    <h1 class="display-4">@welcomeMessage</h1>
    @if (user is not null)
    {
        <h2 class="display-6">
            <a asp-page="/Files/View">Browse your files!</a>
        </h2>
    }
    @if (user is null)
    {
        <form method="post" class="text-start w-50">
            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
            </div>
            <input type="submit" value="Login" class="mb-2 text-lg-center btn btn-primary form-control" />
            <a class="text-sm-center" asp-page="Signup">Don't have an account? Sign up now!</a>

            @if (Model.Error is not null)
            {
                <div class="alert alert-danger">@Model.Error</div>
            }
        </form>
    }
</div>
<!-- TODO: make a view component for this here and in /Account/ -->
<div class="row">
    @if (accessible is [_, ..])
    {
        <div class="col">
            <h2>Files shared with you</h2>
            <ul class="list-group">
                @foreach (var acc in accessible)
                {
                    <li class="list-group-item">
                        <a asp-page="/Files/View" asp-route-path="@acc.acc.Fso.Id"
                           asp-route-type="id">@acc.acc.Fso.Data.Name</a>
                        shared by
                        <a asp-page="/Account/User" asp-route-id="@acc.u.Id">@acc.u.Username</a>
                    </li>
                }
            </ul>
        </div>
    }
    @if (shared is [_, ..])
    {
        <div class="col">
            <h2>Files shared by you</h2>
            <ul class="list-group">
                @foreach (var acc in shared)
                {
                    <li class="list-group-item">
                        <a asp-page="/Files/View" asp-route-path="@acc.Fso.Id"
                           asp-route-type="id">@acc.Fso.Data.Name</a>
                        shared with
                        <a asp-page="/Account/User" asp-route-id="@acc.User.Id">@acc.User.Username</a>
                    </li>
                }
            </ul>
        </div>
    }
</div>
