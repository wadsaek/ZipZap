@page
@using ZipZap.Classes
@model ZipZap.Front.Pages.Files.CreateModel
@{
    ViewData["Title"] = "Create an Fso";
}

<h1>Create</h1>
@if (Model.GetHandler is {} handler)
{
<form method="post" enctype="multipart/form-data" class="w-50">
    <label class="form-label" asp-for="FsoType"></label>
    @Html.DropDownListFor(
    model => model.FsoType,
    new[] { FsoType.RegularFile, FsoType.Directory, FsoType.Symlink }.Select(type => new
    SelectListItem(type.ToString(), type.ToString())),
    null,
    new { OnClick = "setRadioButtons()", Class = "form-select" }
    )
    <div class="mb-1">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control"/>
    </div>
    <style>
        .advanced:open::details-content {
            height: 11.5em;
        }
    </style>
    <label class="form-label">Advanced</label>
    <details class="border border-1 rounded bg-white p-2 advanced mb-1">
        <summary class="lead">
            See
        </summary>
        <hr>
        <div class="d-flex flex-row justify-content-between">
            <div class="mb-1 w-100 pe-2">
                <label asp-for="UId" class="form-label"></label>
                <input asp-for="UId" class="form-control"/>
            </div>
            <div class="mb-1 w-100 ps-2">
                <label asp-for="GId" class="form-label"></label>
                <input asp-for="GId" class="form-control"/>
            </div>
        </div>
        <div class="mb-1">
            <label asp-for="Perms" class="form-label"></label>
            <input asp-for="Perms" class="form-control" placeholder="rw-r--r--"/>
        </div>
    </details>
    <div id="fileSpecific" class="mb-1">
        <label asp-for="File" class="form-label"></label>
        <input asp-for="File" class="form-control"/>
    </div>
    <div id="symlinkSpecific" class="mb-1">
        <label asp-for="Target" class="form-label"></label>
        <input asp-for="Target" class="form-control"/>
    </div>
    <script>
            function setRadioButtons() {
                let selected = FsoType[FsoType.selectedIndex].value
                if (selected === "@FsoType.RegularFile.ToString()")
                    fileSpecific.style.display = "block"
                else
                    fileSpecific.style.display = "none"
                if (selected === "@FsoType.Symlink.ToString()")
                    symlinkSpecific.style.display = "block"
                else
                    symlinkSpecific.style.display = "none"

            }
            setRadioButtons()
    </script>
    @if(@Model.FormError is not null){
        <div class=" mb-2 text-danger" style="width: fit-content;">@Model.FormError</div>
    }
    <input type="submit" class="btn btn-primary-mine" value="Create">
</form>
}
