@page "/Files/Move/{id:guid}"
@using ZipZap.Classes
@model ZipZap.Front.Pages.Files.Move

@{
    ViewData["Title"] = "Edit an Fso";
}
@if (Model.Result is var result and not null){
<form method="post">
        <h1>
            Move @result.Item.Fso.Data.Name
        </h1>
        <div class="mb-1">
            <label asp-for="NewPath" class="form-label"></label>
            <input class="form-control" value="@result.FullPath" asp-for="NewPath" />
        </div>
        @if(!string.IsNullOrWhiteSpace(Model.Error)){
            <div class=" mb-2 text-danger" style="width: fit-content;">@Model.Error</div>
        }
        <input type="submit" class="btn btn-primary-mine" value="Submit changes">
</form>}
