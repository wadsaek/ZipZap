@page "/Files/View/{*path}"
@using ZipZap.Classes
@using ZipZap.Front.Handlers.Files.View
@model ZipZap.Front.Pages.Files.FileViewModel
@{
    ViewData["Title"] = Model.Result?.Specification.Identifier ?? "View Files";
}

<div class="pb-5">
    @if (Model.Result is not null)
    {
        <div class="d-flex justify-content-between">
            @{
                var item = Model.Result.Item;
                var fso = item.Fso;
                var accesses = Model.Result.Accesses;
                ViewData["Title"] = fso.ToString(Fso.ShortListingFormat);
            }
            <div>
                <h1> @fso.ToString(Fso.ShortListingFormat) </h1>
                <div class="d-flex justify-content-between">
                    <h4 class="text-secondary">@fso.Data.Permissions @fso.Data.Ownership </h4>
                </div>
                    <details class="border border-1 rounded p-2 bg-white mb-3 unsized">
                        <summary class="lead">See access info</summary>
                        <hr>
                        @if(accesses is not []){
                            <ul class="list-group">
                                @foreach(var acc in accesses){
                                    <li class="list-group-item">@acc.User.Username</li>
                                }
                            </ul>
                        }
                    </details>
            </div>
            <div class="d-flex flex-column align-items-end justify-content-start">
                <a class="btn btn-primary-mine btn-small mb-2 w-100" href="@Model.Result!.ParentUrl">Up</a>
                @if(item.OwnershipStatus is not OwnershipStatus.Shared){
                    <a class="btn btn-primary-mine btn-small mb-2 w-100" asp-page="/Files/Edit" asp-route-id="@fso.Id.Value">
                        Edit this @FileViewModel.FsoTypeName(fso)
                    </a>
                    <a class="btn btn-primary-mine btn-small mb-2 w-100" asp-page="/Files/Move" asp-route-id="@fso.Id.Value">
                        Move this @FileViewModel.FsoTypeName(fso)
                    </a>
                }
            </div>
        </div>
        @if (fso is Directory dir)
        {

            <div class="d-flex flex-column justify-content-between">
                <h2>Items</h2>
                <div class="d-flex flex-column col-2">
                    <a class="btn btn-primary-mine btn-small mb-2 w-75" asp-page="/Files/Create" asp-route-id="@fso.Id.Value">
                        Create a new item
                    </a>
                </div>
            </div>
            <style>
                .child-fso {
                    &:hover {
                        background-color: #fafafa
                    }
                    transition: all 0.1s
                }
            </style>
            <ul class="list-group">
            @foreach (var child in dir.MaybeChildren
                .OrderBy(f=> f is Directory ? 0 : 1)
                .ThenBy(f=>f.Data.Name,StringComparer.Ordinal)
            ){
                <a href="@Model.Result.GetChildLink(child)" class="child-fso list-group-item d-flex justify-content-between child-fso">
                    <form method="post" onsubmit="return confirm('Are you sure you want to delete this file?')"
                          asp-page-handler="Delete" asp-route-path="@child.Id" asp-route-type="id">
                        <button class="btn text-danger border border-1 p-1 m-1 monospace">X</button>
                        <span >
                            @child.Data.Name
                        </span>
                    </form>
                    @if(@child is Symlink {Target: var target}){
                        <span class="txt text-secondary">&rarr; @target</span>
                    }
                    <span class="text text-secondary">@FileViewModel.FsoTypeName(child)</span>
                </a>
            }
            </ul>
        }
        else if (fso is File)
        {
            @if(Model.Result.Content is GetHandler.Content.TextContent(var text)){
                <details class="border border-1 rounded p-2 bg-white mb-3 unsized">
                    <summary class="lead">
                        The file content could be parsed as text. Do you want to see it?
                    </summary>
                    <hr>
                    <p style="white-space: pre-wrap;">@text</p>
                </details>
            }
        }
    }
</div>
